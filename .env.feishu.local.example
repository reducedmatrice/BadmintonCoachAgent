# Copy this file to `.env.feishu.local` and fill in your local secrets.
# This file is intentionally safe to commit; the real `.env.feishu.local` is ignored.

export FEISHU_APP_ID="your_feishu_app_id"
export FEISHU_APP_SECRET="your_feishu_app_secret"

export DEERFLOW_OPENAI_BASE_URL="https://your-openai-compatible-host/v1"
export DEERFLOW_OPENAI_API_KEY="your_openai_compatible_api_key"
export DEERFLOW_OPENAI_MODEL="your_model_name"
